# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = '1'



def flutter_root
  # Try environment variable first (standard for CI/CD like Codemagic/Appcircle)
  return ENV['FLUTTER_ROOT'] if ENV.key?('FLUTTER_ROOT')

  generated_xcode_build_settings_path = File.expand_path(File.join('Flutter', 'Generated.xcconfig'), File.dirname(__FILE__))
  unless File.exist?(generated_xcode_build_settings_path)
    # If the file is missing and we don't have an environment variable, try to find it via the flutter command
    # This is a last resort fallback
    begin
      return `flutter info --path`.strip
    rescue
      raise "#{generated_xcode_build_settings_path} must exist or FLUTTER_ROOT env var must be set."
    end
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
    return matches[1] if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try rerunning flutter pub get."
end

require File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.generated_projects.each do |project|
    project.targets.each do |target|
      flutter_additional_ios_build_settings(target)
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      end
    end
  end
end
